package components

import "arena-vip/atoms"

type Coach struct {
	Name         string
	Role         string
	Belt         string
	BeltColor    string
	Experience   string
	ExpYears     string
	Modality     string
	Bio          string
	Photo        string
	Achievements []string
	Graduation   int
}

